# Server port (Render sets PORT automatically)
PORT=3001

# JWT signing secret — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Comma-separated frontend URLs for CORS (Vercel URL, local dev)
CLIENT_URL=http://localhost:5173

# --- PostgreSQL (production / optional local) ---
# When set, the app uses PostgreSQL instead of SQLite.
# DATABASE_URL=postgresql://user:password@localhost:5432/corebuild_salary
# PG_SSL=true

# --- SQLite (local dev default when DATABASE_URL is unset) ---
# DATABASE_PATH=./data/production.db
